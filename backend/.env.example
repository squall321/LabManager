# LabManager 백엔드 환경변수 예시
# 운영 배포 시 backend/.env 로 복사해 값을 채우세요. (이 파일은 커밋해도 안전합니다)

# JWT 서명 키 — 운영에서는 반드시 강력한 무작위 값으로 설정하세요.
#   예: python -c "import secrets; print(secrets.token_hex(32))"
# 미설정 시 backend/data/.secret_key 에 배포별 무작위 키가 자동 생성됩니다.
SECRET_KEY=

# 첫 로그인(비밀번호 설정) 시 요구할 조직 가입 코드.
# 설정하면 등록 이메일 + 이 코드를 모두 알아야 계정을 활성화할 수 있어
# 이메일만으로 타인 계정을 선점하는 것을 막습니다. 비워두면(기본) 코드 없이 설정 가능.
SIGNUP_CODE=

# 데이터베이스 (기본: SQLite). 운영 확장 시 PostgreSQL 등으로 교체.
# DATABASE_URL=sqlite:///./data/labmanager.db

# 토큰 만료 (분). 기본 1440(24시간).
# ACCESS_TOKEN_EXPIRE_MINUTES=1440
